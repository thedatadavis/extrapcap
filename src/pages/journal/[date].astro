---
import Shell from '../../layouts/Shell.astro';
import { formatDate, journal, readoutFor } from '../../data/journal';
export function getStaticPaths() {
  return journal.map((entry) => ({ params: { date: entry.date }, props: { entry } }));
}
const { entry } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Shell>
  <header class="topbar"><a class="back-link" href={`${base}/`}>← Overview</a><span>Daily journal</span></header>
  <article class="journal-page">
    <h1>{formatDate(entry.date)}</h1>
    <p class="lede">A plain-language account of the market moves considered, trades passed over, and entries prepared that day.</p>
    <div class="entry-stack">
      {entry.entries.map((item) => {
        const readout = readoutFor(item);
        return (
        <section class="entry-card">
          <div class="entry-meta">
            <span>{readout.label}</span>
            <span class:list={['decision', item.decision]}>{readout.status}</span>
          </div>
          <h2>{readout.headline}</h2>
          <p class="readout-body">{readout.body}</p>
          <details class="technical-details">
            <summary>Technical record</summary>
            <dl>
              <div><dt>Ticker</dt><dd>{item.ticker ?? 'Not applicable'}</dd></div>
              <div><dt>Event</dt><dd>{item.kind === 'paper_order' ? 'order' : item.kind.replaceAll('_', ' ')}</dd></div>
              {item.selectionContext?.sector && <div><dt>Sector</dt><dd>{item.selectionContext.sector}</dd></div>}
              {item.selectionContext?.streak_length !== undefined && <div><dt>Streak</dt><dd>{item.selectionContext.streak_direction} · {item.selectionContext.streak_length} sessions · signed {item.selectionContext.signed_streak}</dd></div>}
              {item.selectionContext?.relative_return !== undefined && <div><dt>Formation</dt><dd>{(Number(item.selectionContext.relative_return) * 100).toFixed(2)}% versus SPY · robust Z {Number(item.selectionContext.robust_z).toFixed(2)}</dd></div>}
              {item.dataTier && <div><dt>Data tier</dt><dd>{item.dataTier}</dd></div>}
              {item.signalId && <div><dt>Signal ID</dt><dd><code>{item.signalId}</code></dd></div>}
              {item.clientOrderId && <div><dt>Client order</dt><dd><code>{item.clientOrderId}</code></dd></div>}
              {item.riskSnapshot?.options_trading_level !== undefined && <div><dt>Account gate</dt><dd>Options Level {item.riskSnapshot.options_trading_level} · {item.riskSnapshot.trading_blocked ? 'blocked' : 'available'}</dd></div>}
              <div><dt>Reason</dt><dd>{item.reason}</dd></div>
            </dl>
            {item.contractIds.length > 0 && <div class="contract-list"><h3>Contract IDs</h3>{item.contractIds.map((contractId) => <p><code>{contractId}</code></p>)}</div>}
          </details>
        </section>
        );
      })}
    </div>
    <p class="journal-footnote">These entries describe decisions and proposed orders; they do not confirm that an order was filled.</p>
  </article>
</Shell>
